# AstroLLM Environment Variables
# Copy to .env and fill in your values

# ── API Keys ──
ANTHROPIC_API_KEY=       # For SFT data generation via Claude
ADS_API_KEY=             # NASA ADS (free: ui.adsabs.harvard.edu/user/settings/token)
WANDB_API_KEY=           # Weights & Biases (free: wandb.ai/settings)
HF_TOKEN=                # Hugging Face (for model downloads)

# ── Database ──
DB_PASSWORD=astrollm_dev
DATABASE_URL=postgres://astrollm:astrollm_dev@localhost:5432/astrollm

# ── Services ──
EMBEDDER_URL=http://localhost:8081
INFERENCE_URL=http://localhost:8080

# ── Cloud GPU (RunPod) ──
RUNPOD_API_KEY=

# ── Cloud GPU (Lambda Labs) ──
LAMBDA_API_KEY=
