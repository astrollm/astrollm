{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AstroLLM SFT Training Example",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"]
          },
          "content": {
            "type": ["string", "null"]
          },
          "tool_calls": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "arguments"],
              "properties": {
                "name": { "type": "string" },
                "arguments": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": ["generated", "curated", "synthetic", "textbook", "paper_analysis"]
        },
        "topic": { "type": "string" },
        "difficulty": {
          "type": "string",
          "enum": ["introductory", "undergraduate", "graduate", "research"]
        },
        "requires_tools": { "type": "boolean" },
        "tools_used": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
