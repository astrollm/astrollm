{
  "project": "astrollm",
  "description": "Domain-specialized LLM for Astronomy & Astrophysics",
  "version": "0.1.0",
  "personas": [
    "ml-engineer",
    "data-engineer",
    "astronomer",
    "frontend-dev",
    "retrieval-engineer",
    "devops",
    "technical-writer",
    "mentor",
    "product-strategist"
  ],
  "defaultPersona": "ml-engineer",
  "permissions": {
    "allow": [
      "read",
      "edit",
      "write",
      "glob",
      "grep",
      "bash:uv *",
      "bash:bun *",
      "bash:git status",
      "bash:git diff*",
      "bash:git log*",
      "bash:git add*",
      "bash:git branch*",
      "bash:docker compose*",
      "bash:ruff *",
      "bash:ls *",
      "bash:mkdir *",
      "bash:cat *",
      "bash:head *",
      "bash:wc *"
    ],
    "deny": [
      "bash:rm -rf *",
      "bash:git push --force*",
      "bash:git reset --hard*",
      "bash:git checkout -- .",
      "bash:git clean -fd*"
    ]
  }
}
